# =============================================================================
# keystore.properties — local signing configuration for the Android app
#
# COPY this file to `keystore.properties` (without the .example suffix)
# in the SAME directory (android/), fill in the four values below, and
# Gradle will sign every build it produces (debug AND release) with your
# release key. The green Run / Debug triangle in Android Studio then
# installs a properly-signed APK on your phone, so passkeys work without
# having to go through the "Generate Signed APK" wizard every time.
#
# THIS FILE IS GITIGNORED. Your real `keystore.properties`, your `.jks`
# file, and your passwords never leave your machine.
#
# How to find each value:
#   - storeFile: absolute path to your .jks / .keystore file.
#       Windows  : D:\\path\\to\\victor-release-key.jks
#                  (use double backslashes OR forward slashes;
#                  Gradle accepts both)
#       Linux/Mac: /home/you/keys/release-key.jks
#   - storePassword: the keystore password you set in Android Studio
#   - keyAlias: the alias inside the keystore (`keytool -list -keystore
#       <file>` will print it; in your case it's `key0`)
#   - keyPassword: the alias password (often the same as storePassword)
#
# If this file is absent, builds still work but produce APKs signed
# with Android Studio's auto-generated debug key — those APKs won't
# match the fingerprint published in /.well-known/assetlinks.json, so
# passkeys won't work inside the app.
# =============================================================================

storeFile=D:/NextCloud/Victor/Documents/AndroidStudio/victor-release-key
storePassword=REPLACE_WITH_YOUR_STORE_PASSWORD
keyAlias=key0
keyPassword=REPLACE_WITH_YOUR_KEY_PASSWORD
