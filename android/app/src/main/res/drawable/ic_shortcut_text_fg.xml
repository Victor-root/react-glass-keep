<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer for the "new text note" shortcut. White glyph
    centred in a 60×60 box (x=24..84) — that's the inner 72×72 safe
    zone with a ~5dp cushion on each side. The cushion is needed
    because launchers with aggressive circular masks (AOSP/Pixel)
    and rotated masks (Oppo) crop slightly past the documented safe
    zone, which was clipping our rectangular icon's corners.
    scale = 60/24 = 2.5
    translate = (108 - 60)/2 = 24
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="24"
        android:translateY="24"
        android:scaleX="2.5"
        android:scaleY="2.5">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M19,3H5c-1.1,0 -2,0.9 -2,2v14c0,1.1 0.9,2 2,2h14c1.1,0 2,-0.9 2,-2V5c0,-1.1 -0.9,-2 -2,-2zm0,16H5V5h14v14zm-2,-6H7v-2h10v2zm-4,4H7v-2h6v2zm4,-8H7V7h10v2z" />
    </group>
</vector>
