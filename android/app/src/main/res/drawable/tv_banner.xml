<?xml version="1.0" encoding="utf-8"?>
<!-- 320x180 launcher banner for Android TV (Leanback). Required dimensions
     when an activity exposes LEANBACK_LAUNCHER. Done as a vector layer-list
     so we avoid shipping a PNG and stay sharp on 4K TVs. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient background — same indigo/violet that defines the GlassKeep
         brand on the login screen and the native swap-server dialog. -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#6366f1"
                android:centerColor="#7c3aed"
                android:endColor="#a78bfa" />
        </shape>
    </item>
    <!-- Centered app logo, generously inset to leave breathing room around
         the artwork the way Material TV banners are expected to look. -->
    <item
        android:left="110dp"
        android:top="36dp"
        android:right="110dp"
        android:bottom="36dp"
        android:drawable="@drawable/glasskeep_logo" />
</layer-list>
