<?xml version="1.0" encoding="utf-8"?>
<!--
  Android TV launcher banner — 320x180 pure vector drawable.
  No PNG references, no system fonts — every shape and every glyph
  is drawn as an SVG path so the banner stays sharp at any density.

  Composition (top to bottom):
    1. Rounded rectangle backdrop with the app's signature
       indigo-500 → violet-600 diagonal gradient.
    2. Recreation of the GlassKeep app icon: a glassmorphism note
       card with spiral-coil binding rings on top and a few text
       lines suggested inside.
    3. "GLASSKEEP" wordmark in custom geometric bold glyphs (each
       letter is a single path).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- ===== 1. Backdrop ===== -->
    <!-- Rounded 14dp corners. Diagonal gradient using the same
         indigo→violet pair as the .btn-gradient buttons in-app. -->
    <path android:pathData="M14,0 L306,0 A14,14 0 0 1 320,14 L320,166 A14,14 0 0 1 306,180 L14,180 A14,14 0 0 1 0,166 L0,14 A14,14 0 0 1 14,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="320" android:endY="180"
                android:startColor="#6366f1"
                android:endColor="#7c3aed" />
        </aapt:attr>
    </path>

    <!-- Soft top-left highlight for depth. Matches the gloss on the
         original PNG icon. -->
    <path android:pathData="M14,0 L170,0 L0,170 L0,14 A14,14 0 0 1 14,0 Z"
        android:fillColor="#ffffff"
        android:fillAlpha="0.08" />

    <!-- ===== 2. Note-card icon (44w × 56h, positioned top-centre) ===== -->
    <group android:translateX="138" android:translateY="10">
        <!-- Spiral coil rings: five small open circles riding on a
             horizontal "wire" above the card. -->
        <path android:pathData="M0,8 L44,8"
            android:strokeColor="#ffffff"
            android:strokeAlpha="0.6"
            android:strokeWidth="1.5"
            android:strokeLineCap="round" />
        <path android:pathData="M5,8 m-2.5,0 a2.5,2.5 0 1 0 5,0 a2.5,2.5 0 1 0 -5,0 M14,8 m-2.5,0 a2.5,2.5 0 1 0 5,0 a2.5,2.5 0 1 0 -5,0 M22,8 m-2.5,0 a2.5,2.5 0 1 0 5,0 a2.5,2.5 0 1 0 -5,0 M30,8 m-2.5,0 a2.5,2.5 0 1 0 5,0 a2.5,2.5 0 1 0 -5,0 M39,8 m-2.5,0 a2.5,2.5 0 1 0 5,0 a2.5,2.5 0 1 0 -5,0"
            android:strokeColor="#ffffff"
            android:strokeWidth="1.8"
            android:fillColor="#00000000" />

        <!-- Card body. Rounded 6dp, white with high alpha so it reads
             as a glassmorphism surface over the violet backdrop. -->
        <path android:pathData="M4,12 L40,12 A4,4 0 0 1 44,16 L44,52 A4,4 0 0 1 40,56 L4,56 A4,4 0 0 1 0,52 L0,16 A4,4 0 0 1 4,12 Z"
            android:fillColor="#ffffff"
            android:fillAlpha="0.92" />

        <!-- Subtle glass highlight on the card top-left. -->
        <path android:pathData="M4,12 L26,12 L4,34 L0,30 L0,16 A4,4 0 0 1 4,12 Z"
            android:fillColor="#ffffff"
            android:fillAlpha="0.18" />

        <!-- Four "text" lines inside the card — violet, rounded
             caps, descending widths. -->
        <path android:pathData="M6,22 L38,22"
            android:strokeColor="#7c3aed"
            android:strokeAlpha="0.65"
            android:strokeWidth="2.4"
            android:strokeLineCap="round" />
        <path android:pathData="M6,30 L32,30"
            android:strokeColor="#7c3aed"
            android:strokeAlpha="0.65"
            android:strokeWidth="2.4"
            android:strokeLineCap="round" />
        <path android:pathData="M6,38 L38,38"
            android:strokeColor="#7c3aed"
            android:strokeAlpha="0.65"
            android:strokeWidth="2.4"
            android:strokeLineCap="round" />
        <path android:pathData="M6,46 L26,46"
            android:strokeColor="#7c3aed"
            android:strokeAlpha="0.65"
            android:strokeWidth="2.4"
            android:strokeLineCap="round" />
    </group>

    <!-- ===== 3. "GLASSKEEP" wordmark ===== -->
    <!-- 9 glyphs × 18w + 8 × 4 spacing = 194w. Centered on 320 → x=63.
         Each glyph fits in a 18w × 24h cell, cap height 24, drawn as a
         single filled path. fillType:evenOdd carves out counters
         (the holes inside A and P). -->
    <group android:translateX="63" android:translateY="108">

        <!-- G -->
        <path android:pathData="M4,0 L14,0 C16.2,0 18,1.8 18,4 L18,7 L14,7 L14,5 C14,4.4 13.6,4 13,4 L5,4 C4.4,4 4,4.4 4,5 L4,19 C4,19.6 4.4,20 5,20 L13,20 C13.6,20 14,19.6 14,19 L14,15 L10,15 L10,11 L18,11 L18,20 C18,22.2 16.2,24 14,24 L4,24 C1.8,24 0,22.2 0,20 L0,4 C0,1.8 1.8,0 4,0 Z"
            android:fillColor="#ffffff" />

        <!-- L (x=22) -->
        <path android:pathData="M22,0 L26,0 L26,20 L36,20 L36,24 L22,24 Z"
            android:fillColor="#ffffff" />

        <!-- A (x=40) — outer + inner triangle via evenOdd -->
        <path android:pathData="M48,0 L52,0 L60,24 L56,24 L54.7,20 L45.3,20 L44,24 L40,24 Z M46.6,16 L53.4,16 L50,6 Z"
            android:fillColor="#ffffff"
            android:fillType="evenOdd" />

        <!-- S (x=62) -->
        <path android:pathData="M77,0 C79.2,0 80,1.8 80,4 L80,5 L76,5 L76,4.5 C76,4.2 75.8,4 75.5,4 L66.5,4 C66.2,4 66,4.2 66,4.5 L66,8.5 C66,9.2 66.5,10 67.5,10 L77,10 C79.2,10 80,11.8 80,14 L80,20 C80,22.2 79.2,24 77,24 L65,24 C62.8,24 62,22.2 62,20 L62,19 L66,19 L66,19.5 C66,19.8 66.2,20 66.5,20 L75.5,20 C75.8,20 76,19.8 76,19.5 L76,15.5 C76,14.8 75.5,14 74.5,14 L65,14 C62.8,14 62,12.2 62,10 L62,4 C62,1.8 62.8,0 65,0 Z"
            android:fillColor="#ffffff" />

        <!-- S (x=82) — same shape, translated -->
        <path android:pathData="M97,0 C99.2,0 100,1.8 100,4 L100,5 L96,5 L96,4.5 C96,4.2 95.8,4 95.5,4 L86.5,4 C86.2,4 86,4.2 86,4.5 L86,8.5 C86,9.2 86.5,10 87.5,10 L97,10 C99.2,10 100,11.8 100,14 L100,20 C100,22.2 99.2,24 97,24 L85,24 C82.8,24 82,22.2 82,20 L82,19 L86,19 L86,19.5 C86,19.8 86.2,20 86.5,20 L95.5,20 C95.8,20 96,19.8 96,19.5 L96,15.5 C96,14.8 95.5,14 94.5,14 L85,14 C82.8,14 82,12.2 82,10 L82,4 C82,1.8 82.8,0 85,0 Z"
            android:fillColor="#ffffff" />

        <!-- K (x=104) -->
        <path android:pathData="M104,0 L108,0 L108,9.6 L116.4,0 L121.4,0 L113,10.5 L122,24 L117,24 L110.5,14 L108,17 L108,24 L104,24 Z"
            android:fillColor="#ffffff" />

        <!-- E (x=126) -->
        <path android:pathData="M126,0 L142,0 L142,4 L130,4 L130,10 L141,10 L141,14 L130,14 L130,20 L142,20 L142,24 L126,24 Z"
            android:fillColor="#ffffff" />

        <!-- E (x=146) -->
        <path android:pathData="M146,0 L162,0 L162,4 L150,4 L150,10 L161,10 L161,14 L150,14 L150,20 L162,20 L162,24 L146,24 Z"
            android:fillColor="#ffffff" />

        <!-- P (x=166) — outer + inner hole via evenOdd -->
        <path android:pathData="M166,0 L178,0 C181.3,0 184,2.7 184,6 L184,10 C184,13.3 181.3,16 178,16 L170,16 L170,24 L166,24 Z M170,4 L170,12 L177,12 C178.7,12 180,10.7 180,9 L180,7 C180,5.3 178.7,4 177,4 Z"
            android:fillColor="#ffffff"
            android:fillType="evenOdd" />
    </group>
</vector>
