<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- In-app self-update: fetch the latest APK from GitHub Releases,
         drop it into our private cache, then hand it to Android's
         system installer via the FileProvider declared below. The user
         has to flip "Install unknown apps" for GlassKeep once; after
         that, future updates trigger the native "Update?" dialog
         straight from a background check on launch. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- The self-updater posts a non-intrusive notification when a new
         release is available; tap-to-download. Runtime grant required
         on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <!-- TV support: declare leanback as optional and touchscreen as not required so
         the same APK can be installed on phones, tablets AND Android TV devices
         (Nvidia Shield, Chromecast with Google TV, etc). -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.hardware.faketouch" android:required="false" />

    <application
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:banner="@drawable/tv_banner"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlassKeep"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Show in the Android TV "Apps" row alongside touch launchers. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- Long-press the launcher icon → "Scan PC login" shortcut.
                 See res/xml/shortcuts.xml + MainActivity.onCreate. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".WebViewActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode" />

        <!-- Self-update FileProvider: lets us hand the downloaded APK to
             Android's system installer (ACTION_VIEW with
             application/vnd.android.package-archive) without granting
             external-storage permissions. The authority follows the
             applicationId so it stays unique across forks / build types. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Self-update notification tap target. The update-available
             notification fires this receiver with the parsed release
             metadata; the receiver kicks off the silent background
             download + system install intent. -->
        <receiver
            android:name=".update.UpdateActionReceiver"
            android:exported="false" />
    </application>
</manifest>
